        ],
        "type": "object"
      },
      "PublicHealthResponse": {
        "description": "Response body for GET /health (unauthenticated).",
        "properties": {
          "status": {
            "description": "Health status string.",
            "example": "healthy",
            "type": "string"
          },
          "uptime_secs": {
            "description": "Uptime in seconds.",
            "example": 120,
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "status",
          "uptime_secs"
        ],
        "type": "object"
      },
      "ResponsesFunction": {
        "description": "Function definition for a responses tool.",
        "properties": {
          "description": {
            "description": "Human-readable description.",
            "type": "string"
          },
          "name": {
            "description": "Function name.",
            "type": "string"
          },
          "parameters": {
            "description": "JSON Schema for parameters."
          }
        },
        "required": [
          "name",
          "description",
          "parameters"
        ],
        "type": "object"
      },
      "ResponsesInput": {
        "description": "Input for a responses request.",
        "oneOf": [
          {
            "description": "Simple text input.",
            "type": "string"
          },
          {
            "description": "Array of messages.",
            "items": {
              "$ref": "#/components/schemas/ResponsesInputMessage"
            },
            "type": "array"
          }
        ]
      },
      "ResponsesInputMessage": {
        "description": "A single input message.",
        "properties": {
          "content": {
            "description": "Message content.",
            "type": "string"
          },
          "role": {
            "description": "Role: \"user\", \"assistant\", etc.",
            "type": "string"
          }
        },
        "required": [
          "role",
          "content"
        ],
        "type": "object"
      },
      "ResponsesRequest": {
        "description": "POST /v1/responses request body.",
        "properties": {
          "input": {
            "$ref": "#/components/schemas/ResponsesInput",
            "description": "Input — either a plain text string or an array of messages."
          },
          "instructions": {
            "description": "System instructions for the model.",
            "type": [
              "string",
              "null"
            ]
          },
          "max_output_tokens": {
            "description": "Maximum output tokens.",
            "format": "int32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "model": {
            "description": "Model identifier (supports provider/model format).",
            "type": "string"
          },
          "previous_response_id": {
            "description": "Previous response ID for multi-turn conversations.",
            "type": [
              "string",
              "null"
            ]
          },
          "stream": {
            "description": "Whether to stream the response (default: true).",
            "type": "boolean"
          },
          "temperature": {
            "description": "Sampling temperature.",
            "format": "float",
            "type": [
              "number",
              "null"
            ]
          },
          "tools": {
            "description": "Tool definitions.",
            "items": {
              "$ref": "#/components/schemas/ResponsesTool"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "model",
          "input"
        ],
        "type": "object"
      },
      "ResponsesTool": {
        "description": "A tool definition in the responses API.",
        "properties": {
          "function": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponsesFunction",
                "description": "Function definition (for type=\"function\")."
              }
            ]
          },
          "name": {
            "description": "Built-in tool name (for non-function tools).",
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "description": "Tool type (\"function\" or built-in like \"web_search\").",
            "type": "string"
          }
        },
        "required": [
          "type"
        ],
        "type": "object"
      },
      "SessionInfo": {
        "description": "Information about a single session.",
        "properties": {
          "channel": {
            "description": "Channel the session originates from.",
            "example": "api",
            "type": "string"
          },
          "created_at": {
            "description": "ISO 8601 creation timestamp.",
            "example": "2026-03-13T12:00:00Z",
            "type": "string"
          },
          "id": {
            "description": "Session identifier.",
            "example": "sess-abc123",
            "type": "string"
          },
          "state": {
            "description": "Session state.",
            "example": "active",
            "type": "string"
          }
        },
        "required": [
          "id",
          "channel",
          "state",
          "created_at"
        ],
        "type": "object"
      },
      "SessionListResponse": {
        "description": "Response body for GET /v1/sessions.",
        "properties": {
          "sessions": {
            "description": "List of active sessions.",
            "items": {
              "$ref": "#/components/schemas/SessionInfo"
            },
            "type": "array"
          }
        },
        "required": [
          "sessions"
        ],
        "type": "object"
      },
      "ToolFunctionInfo": {
        "description": "Function info within a ToolInfo.",
        "properties": {
          "description": {
            "description": "Human-readable description.",
            "type": "string"
          },
          "name": {
            "description": "Function name.",
            "type": "string"
          },
          "parameters": {
            "description": "JSON Schema for parameters."
          }
        },
        "required": [
          "name",
          "description",
          "parameters"
        ],
        "type": "object"
      },
      "ToolInfo": {
        "description": "Extended tool info in OpenAI function schema format.",
        "properties": {
          "function": {
            "$ref": "#/components/schemas/ToolFunctionInfo",
            "description": "Function definition."
          },
          "required_permissions": {
            "description": "Extended: required permissions/capabilities.",
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "source": {
            "description": "Extended: tool source (\"builtin\", \"wasm\", \"mcp\").",
            "type": "string"
          },
          "type": {
            "description": "Tool type (always \"function\").",
            "type": "string"
          },
          "version": {
            "description": "Extended: tool version (if available).",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "type",
          "function",
          "source"
        ],
        "type": "object"
      },
      "ToolInvokeRequest": {
        "description": "Request body for POST /v1/tools/invoke.",
        "properties": {
          "input": {
            "description": "JSON input to pass to the tool."
          },
          "name": {
            "description": "Tool name to invoke.",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "ToolInvokeResponse": {
        "description": "Response body for POST /v1/tools/invoke.",
        "properties": {
          "duration_ms": {
            "description": "Execution time in milliseconds.",
            "format": "int64",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "is_error": {
            "description": "Whether the execution resulted in an error.",
            "type": "boolean"
          },
          "name": {
            "description": "Tool name that was invoked.",
            "type": "string"
          },
          "output": {
            "description": "Tool execution output.",
            "type": "string"
          }
        },
        "required": [
          "name",
          "output",
          "is_error"
        ],
        "type": "object"
      },
      "ToolListResponse": {
        "description": "Response for GET /v1/tools.",
        "properties": {
          "data": {
            "description": "Tool data.",
            "items": {
              "$ref": "#/components/schemas/ToolInfo"
            },
            "type": "array"
          },
          "object": {
            "description": "Object type (always \"list\").",
            "type": "string"
          }
        },
        "required": [
          "object",
          "data"
        ],
        "type": "object"
      },
      "WebhookListItem": {
        "description": "A webhook list item (never exposes the secret).",
        "properties": {
          "active": {
            "description": "Whether the webhook is active.",
            "type": "boolean"
          },
          "created_at": {
            "description": "ISO 8601 creation timestamp.",
            "type": "string"
          },
          "events": {
            "description": "Event types this webhook subscribes to.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "description": "Unique webhook identifier.",
            "type": "string"
          },
          "url": {
            "description": "Delivery URL.",
            "type": "string"
          }
        },
        "required": [
          "id",
          "url",
          "events",
          "active",
          "created_at"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Blufio Contributors"
    },
    "description": "Always-on personal AI agent REST API",
    "license": {
      "name": "MIT OR Apache-2.0"
    },
    "title": "Blufio API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Returns basic health status for systemd health checks and monitoring.\nDoes not require authentication. Returns minimal information.",
        "operationId": "get_public_health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicHealthResponse"
                }
              }
            },
            "description": "Service healthy"
          }
        },
        "summary": "GET /health (unauthenticated)",
        "tags": [
          "Health"
        ]
      }
    },
    "/metrics": {
      "get": {
        "description": "Returns Prometheus metrics in text format for scraping.\nDoes not require authentication.",
        "operationId": "get_public_metrics",
        "responses": {
          "200": {
            "content": {
              "text/plain": {}
            },
            "description": "Prometheus metrics"
          },
          "503": {
            "description": "Metrics not available"
          }
        },
        "summary": "GET /metrics (unauthenticated)",
        "tags": [
          "Health"
        ]
      }
    },
    "/v1/api-keys": {
      "get": {
        "description": "Requires admin scope or master auth. Never exposes key hashes.",
        "operationId": "get_list_api_keys",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ApiKey"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of API keys"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/api-keys -- List all API keys.",
        "tags": [
          "API Keys"
        ]
      },
      "post": {
        "description": "Requires admin scope or master auth. Returns the raw key once.",
        "operationId": "post_create_api_key",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKeyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateKeyResponse"
                }
              }
            },
            "description": "API key created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/api-keys -- Create a new scoped API key.",
        "tags": [
          "API Keys"
        ]
      }
    },
    "/v1/api-keys/{id}": {
      "delete": {
        "description": "Requires admin scope or master auth. Revokes rather than deletes\nso the key is immediately rejected on all endpoints.",
        "operationId": "delete_api_key",
        "parameters": [
          {
            "description": "API key ID to revoke",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Key revoked"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "DELETE /v1/api-keys/:id -- Revoke an API key.",
        "tags": [
          "API Keys"
        ]
      }
    },
    "/v1/batch": {
      "post": {
        "description": "Requires chat.completions, admin scope, or master auth.\nReturns 202 Accepted with batch_id for status polling.",
        "operationId": "post_create_batch",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchSubmitResponse"
                }
              }
            },
            "description": "Batch accepted for processing"
          },
          "400": {
            "description": "Invalid batch (empty or too large)"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Insufficient scope"
          },
          "500": {
            "description": "Internal server error"
          },
          "503": {
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/batch -- Submit a batch of chat completion requests.",
        "tags": [
          "Batch"
        ]
      }
    },
    "/v1/batch/{id}": {
      "get": {
        "description": "For scoped keys, verifies the batch was submitted by the same key.",
        "operationId": "get_batch_status",
        "parameters": [
          {
            "description": "Batch ID to check status",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchResponse"
                }
              }
            },
            "description": "Batch status and results"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Batch not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/batch/:id -- Get batch status and results.",
        "tags": [
          "Batch"
        ]
      }
    },
    "/v1/chat/completions": {
      "post": {
        "description": "Accepts OpenAI-compatible chat completion requests and returns responses\nin the same format. Supports both streaming (SSE) and non-streaming modes.\nWhen `stream: true`, returns Server-Sent Events with `data: [JSON]` chunks.",
        "operationId": "post_chat_completions",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GatewayCompletionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayCompletionResponse"
                }
              }
            },
            "description": "Chat completion response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Provider not found"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Provider error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/chat/completions",
        "tags": [
          "OpenAI Compatible"
        ]
      }
    },
    "/v1/health": {
      "get": {
        "description": "Returns health status of the gateway, including degradation state when\nthe resilience subsystem is wired in. Returns 503 for L4+ degradation.",
        "operationId": "get_health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service healthy"
          },
          "401": {
            "description": "Unauthorized"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service degraded"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/health",
        "tags": [
          "Health"
        ]
      }
    },
    "/v1/messages": {
      "post": {
        "description": "Accepts a message, routes it through the agent loop, and returns the response.\nIf the Accept header contains \"text/event-stream\", routes to SSE streaming.",
        "operationId": "post_messages",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            },
            "description": "Message processed"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Service unavailable"
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timeout"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/messages",
        "tags": [
          "Messages"
        ]
      }
    },
    "/v1/models": {
      "get": {
        "description": "Returns a list of available models across all configured providers.",
        "operationId": "get_models",
        "parameters": [
          {
            "description": "Filter by provider name.",
            "in": "query",
            "name": "provider",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsListResponse"
                }
              }
            },
            "description": "Model list"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/models",
        "tags": [
          "OpenAI Compatible"
        ]
      }
    },
    "/v1/responses": {
      "post": {
        "description": "Accepts OpenResponses-format requests and streams semantic events\ncompatible with the OpenAI Agents SDK. Only streaming mode is supported.\nReturns Server-Sent Events with semantic event types: response.created,\noutput_item.added, content_part.added, output_text.delta, output_text.done,\ncontent_part.done, output_item.done, response.completed.",
        "operationId": "post_responses",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResponsesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Streaming semantic events (SSE)"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Provider not found"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/responses",
        "tags": [
          "OpenAI Compatible"
        ]
      }
    },
    "/v1/sessions": {
      "get": {
        "description": "Returns list of active sessions from storage.",
        "operationId": "get_sessions",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionListResponse"
                }
              }
            },
            "description": "Session list"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/sessions",
        "tags": [
          "Sessions"
        ]
      }
    },
    "/v1/tools": {
      "get": {
        "description": "Returns a list of available tools in OpenAI function schema format.\nOnly tools in the config allowlist are returned.",
        "operationId": "get_tools",
        "parameters": [
          {
            "description": "Filter by tool source: \"builtin\", \"wasm\", \"mcp\".",
            "in": "query",
            "name": "source",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolListResponse"
                }
              }
            },
            "description": "Tool list"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "GET /v1/tools",
        "tags": [
          "OpenAI Compatible"
        ]
      }
    },
    "/v1/tools/invoke": {
      "post": {
        "description": "Executes a tool directly (bypassing the LLM) and returns the result.\nOnly tools in the config allowlist can be invoked.",
        "operationId": "post_tool_invoke",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolInvokeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolInvokeResponse"
                }
              }
            },
            "description": "Tool execution result"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Tool not in allowlist"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Tool not found"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayErrorResponse"
                }
              }
            },
            "description": "Tools not configured"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "summary": "POST /v1/tools/invoke",
        "tags": [
          "OpenAI Compatible"
        ]
      }
    },
