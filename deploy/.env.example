# ┌─────────────────────────────────────────────────────────┐
# │ Blufio Environment Configuration                       │
# │                                                        │
# │ Copy to .env in the project root (next to              │
# │ docker-compose.yml) and fill in your values.           │
# │                                                        │
# │ All variables are optional unless marked REQUIRED.     │
# └─────────────────────────────────────────────────────────┘

# ── Deployment ──────────────────────────────────────────────
# Host port mapping (container always listens on 3000 internally).
# BLUFIO_PORT=3000

# Log verbosity. Options: error, warn, info, debug, trace.
# RUST_LOG=blufio=info

# ── AI Provider API Keys ────────────────────────────────────
# At least one provider key is required for the agent to function.

# Anthropic (Claude) — primary provider.
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — alternative/fallback provider.
# OPENAI_API_KEY=sk-...

# Ollama — local inference (no key needed, set base URL in config.toml).

# OpenRouter — multi-provider routing.
# OPENROUTER_API_KEY=sk-or-...

# Google Gemini — Google AI provider.
# GEMINI_API_KEY=...

# ── Channel Tokens ─────────────────────────────────────────
# Enable channels by uncommenting and providing tokens.
# Each channel also needs configuration in config.toml.

# Telegram bot token (from @BotFather).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Discord bot token (from Discord Developer Portal).
# DISCORD_TOKEN=...

# Slack bot token (from Slack App settings).
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp Cloud API credentials (from Meta Business).
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_VERIFY_TOKEN=...

# Signal (requires signal-cli sidecar — see docs).
# No env vars needed; configured in config.toml.

# IRC (credentials in config.toml, not env vars).

# Matrix (credentials in config.toml).

# ── Gateway ─────────────────────────────────────────────────
# Bearer token for HTTP API authentication.
# If unset, the gateway API has no authentication.
# BLUFIO_GATEWAY_BEARER_TOKEN=...

# ── Vault ───────────────────────────────────────────────────
# Master password for the encrypted vault.
# If unset, vault operations will prompt (not available in Docker).
# BLUFIO_VAULT_PASSWORD=...
